{
  "name": "meridian",
  "version": "0.1.0",
  "description": "Local data enrichment library for IP and city datasets.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maxmind/geoip2-node": "^6.1.0",
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
